<div class="container mt-4">
    <h2>Edit Task</h2> 
    <form action="/editTask/{{task.task_id}}" method="POST">
    
    <div class="mb-3">
        <label for="body" class="form-label">Task Content</label>
        <textarea class="form-control" id="body" name="body" rows="3" required>{{task.body}}</textarea>
    </div>
    <div class="mb-3">
        <label for="due_at" class="form-label">Due Date</label>
        <input type="datetime-local" class="form-control" id="due_at" name="due_at" value="{{task.due_at_input}}" required>
    </div>
    <div class="mb-3 form-check">
        <input type="checkbox" class="form-check-input" id="will_remind" name="will_remind" value="true"
        {{#if task.will_remind}} checked{{/if}}>
        <label class="form-check-label" for="will_remind">Remind me</label>
    </div>
    <button type="submit" class="btn btn-success">Update Task</button>

    <a href="/tasks" class="btn btn-secondary">Cancel</a>

    </form>
</div>