<div class="container my-4 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <form action="/notes" method="GET" class="mb-3">
                <input type="search" name="search" value="{{search}}" class="form-control form-control-lg shadow-sm"
                    placeholder="Search notes" aria-label="Search notes">
            </form>
            <p>Welcome to your notes, {{user.username}}</p>
        </div>
    </div>
</div>

{{!-- This container uses express to automatically render notes, it renders each notes title, body, time made, and tags.
--}}
<section id="notes-container" class="container">
    <ul class="list-unstyled"> {{#each notes}}
        <li class="mb-3">
            <div class="card">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">{{this.title}}</h5>
                    <p class="card-text">{{this.body}}</p>
                    <div class="tag-badges d-flex flex-wrap gap-1 mb-2" data-note-id="{{this.note_id}}">
                        {{!-- tag badges go inside me --}}
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <small class="text-muted">Created: {{this.time_made}}</small>
                        <div class="d-flex gap-2">
                            <form action="/delete/{{this.note_id}}" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('Are you sure you want to delete this note?')">
                                    Delete
                                </button>
                            </form>
                            <a href="/export/{{this.note_id}}" class="btn btn-sm btn-primary">Export</a>
                            <a href="/edit/{{this.note_id}}" class="btn btn-sm btn-primary">Edit</a>
                            <button class="btn btn-sm btn-primary" onclick="displayTags(this, {{this.note_id}})">
                                Tags
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </li> {{/each}}
    </ul>
</section>

{{!-- Tags Container --}}
<div id="tags-container" style="display:none;">
    <div id="tag-list" class="d-flex flex-column gap-1">
    </div>
    <hr class="my-2 border-secondary">
    <div class="d-flex gap-2 align-items-center mb-2">
        <input type="color" id="tag-color-picker" value="#485696">
        <input type="text" id="tag-name-input" placeholder="Tag name..." class="form-control form-control-sm">
    </div>
    <button id="add-tag-button" class="btn btn-sm btn-outline-light w-100">
        + Create New Tag
    </button>
</div>