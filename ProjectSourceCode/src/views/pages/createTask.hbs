<h2>Create a New Task</h2>
{{#if user}}
<p class="user-status">Signed in as <strong>{{user.username}}</strong></p>
{{/if}}
<form action="/createTask" method="POST">
<div class="form-group mb-3">
    <label for="body">task description</label>
        <input type="text" id="body" name="body" class="form-control" placeholder="Enter task description..." required>
</div>
<div class="form-group mb-3">
    <label for="due_at">Due Date</label>
    <input type="datetime-local" id="due_at" name="due_at" class="form-control" required>
</div>
<div class="form-check mb-3">
    <input type="checkbox" class="form-check-input" id="will_remind" name="will_remind" value="true">
    <label class="form-check-label" for="will_remind">Remind me</label>
</div>
<div class="actions">
        <button type="submit" class="btn btn-primary">Create Task</button>
        <a href="/home" class="btn btn-secondary">Cancel</a>
    </div>
</form>