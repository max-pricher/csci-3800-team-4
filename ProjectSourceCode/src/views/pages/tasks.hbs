<h2>My Tasks</h2>
{{#if user}}
<p class="user-status">Signed in as <strong>{{user.username}}</strong></p>
{{/if}}
<!--summary of overdue and upcoming Tasks-->
<div class="task-summary mb-4 d-flex gap-3">
    <span class="badge bg-primary fs-6">
        Overdue tasks: {{counts.overdue_tasks}}
    </span>
    <span class="badge bg-primary fs-6">
        tasks this week: {{counts.current_tasks}}
    </span>
</div>

<div data-overdue="{{counts.overdue_tasks}}" data-week="{{counts.current_tasks}}"></div>

<!--search bar -->
<form method="GET" action="/tasks" class="mb-4 d-flex gap-2">
    <input type="text" name="search" class="form-control" placeholder="search tasks..." value="{{search}}">
    <button type="submit" class="btn btn-outline-secondary">
        Search
    </button>
    <!--add clear function here? -->
</form>
<!--overdue tasks -->
{{#if overdue.length}}<!--only shows if overdue has values-->
<section class="mb-5">
    <h3 class="text-danger"> Overdue:</h3>
    <div class="list-group">
        {{#each overdue}}<!--code will repeat for each element in overdue -->
        <div class="list-group-item list-group-item-danger d-flex justify-content-between align-items-start">
            <div>
                <p class="mb-1 fw-bold">
                    {{this.body}}
                </p>
                <small>Due: {{this.due_at_formatted}}</small>
            </div>
            <!-- add edit/delete task option here? -->
            <div class="d-flex gap-2 ms-3">
                <a href="/editTask/{{this.task_id}}" method="POST" class="d-inline">Edit</a>
                <form action="/deleteTask/{{this.task_id}}" method="POST" class="d-inline">
                 <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this task?')">Delete</button>
                </form>
            </div>
        </div>
        {{/each}}
    </div>
</section>
{{/if}}
<!-- tasks due this week-->
{{#if thisWeek.length}}
<section class="mb-5">
    <h3 class="text-sale"> tasks this week:</h3>
    <div class="list-group">
        {{#each thisWeek}}
        <div class="list-group-item list-group-item-sale d-flex justify-content-between align-items-start">
            <div>
                <p class="mb-1 fw-bold">
                    {{this.body}}
                </p>
                <small>Due: {{this.due_at_formatted}}</small>
            </div>
        <div class="d-flex gap-2 ms-3">
                <a href="/editTask/{{this.task_id}}" method="POST" class="d-inline">Edit</a>
                <form action="/deleteTask/{{this.task_id}}" method="POST" class="d-inline">
                 <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this task?')">Delete</button>
                </form>
            </div>
        </div>
        {{/each}}
    </div>
</section>
{{/if}}
<!-- tasks due after this week-->
{{#if future.length}}
<section class="mb-5">
    <h3 class="text-sale"> tasks after this week:</h3>
    <div class="list-group">
        {{#each future}}
        <div class="list-group-item list-group-item-sale d-flex justify-content-between align-items-start">
            <div>
                <p class="mb-1 fw-bold">
                    {{this.body}}
                </p>
                <small>Due: {{this.due_at_formatted}}</small>
            </div>
        <div class="d-flex gap-2 ms-3">
                <a href="/editTask/{{this.task_id}}" method="POST" class="d-inline">Edit</a>
                <form action="/deleteTask/{{this.task_id}}" method="POST" class="d-inline">
                 <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this task?')">Delete</button>
                </form>
            </div>
        </div>
        {{/each}}
    </div>
</section>
{{/if}}